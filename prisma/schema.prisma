datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  BUYER
  CREATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  SUSPENDED
}

enum RaffleStatus {
  DRAFT
  PENDING_APPROVAL
  OPEN
  PAUSED
  SOLD_OUT
  DRAWING
  FINISHED
  CANCELLED
  REJECTED
}

enum DrawMethod {
  PLATFORM_RANDOM
  LOTERIA_FEDERAL
}

enum TicketStatus {
  RESERVED
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum FinancialTransactionType {
  SALE
  PLATFORM_FEE
  CREATOR_EARNING
  REFUND
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  phone             String?
  cpf               String     @unique
  passwordHash      String
  role              UserRole   @default(BUYER)
  status            UserStatus @default(ACTIVE)
  isVerifiedCreator Boolean    @default(false)
  pixKey            String?
  balanceCents      Int        @default(0)
  blockedAt         DateTime?
  blockedBy         String?    
  blockReason       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  raffles             Raffle[]            @relation("CreatorRaffles")
  wonRaffles          Raffle[]            @relation("RaffleWinner")
  tickets             Ticket[]
  payments            Payment[]
  withdrawalRequests  WithdrawalRequest[] @relation("UserWithdrawals")
  reviewedWithdrawals WithdrawalRequest[] @relation("WithdrawalReviewer")
  platformFees           PlatformFee[]
  auditLogs              AuditLog[]
  creatorTransactions    FinancialTransaction[] @relation("CreatorTransactions")
  buyerTransactions      FinancialTransaction[] @relation("BuyerTransactions")

  @@index([role, createdAt])
  @@index([status])
  @@index([isVerifiedCreator])
}

model Raffle {
  id               String       @id @default(uuid())
  creatorId        String
  title            String
  description      String
  imageUrl         String?
  totalTickets     Int
  soldTicketsCount Int          @default(0)
  ticketPriceCents Int
  drawMethod       DrawMethod
  drawDate         DateTime?
  loteriaNumber    String?
  status           RaffleStatus @default(DRAFT)
  rejectionReason  String?
  pauseReason      String?
  winnerId         String?
  winnerTicketId   String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  creator      User    @relation("CreatorRaffles", fields: [creatorId], references: [id])
  winner       User?   @relation("RaffleWinner", fields: [winnerId], references: [id])
  winnerTicket Ticket? @relation("WinningTicket", fields: [winnerTicketId], references: [id])
  tickets               Ticket[]
  draw                  Draw?
  financialTransactions FinancialTransaction[]

  @@index([status, createdAt])
  @@index([creatorId])
}

model Ticket {
  id        String       @id @default(uuid())
  raffleId  String
  buyerId   String
  number        Int
  status        TicketStatus @default(RESERVED)
  reservedUntil DateTime?
  createdAt     DateTime     @default(now())

  raffle        Raffle   @relation(fields: [raffleId], references: [id])
  buyer         User     @relation(fields: [buyerId], references: [id])
  payment       Payment?
  winningRaffle Raffle?  @relation("WinningTicket")
  draws         Draw[]

  @@unique([raffleId, number])
  @@index([raffleId, status])
  @@index([buyerId])
  @@index([status, reservedUntil])
}

model Payment {
  id            String        @id @default(uuid())
  ticketId      String        @unique
  userId        String
  amountCents   Int
  pixTxId       String        @unique
  pixQrCode     String
  pixExpiration DateTime?
  confirmedAt   DateTime?
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  ticket                Ticket                 @relation(fields: [ticketId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id])
  financialTransactions FinancialTransaction[]
  auditLogs             PaymentAuditLog[]

  @@index([userId])
  @@index([status])
  @@index([confirmedAt])
}

model FinancialTransaction {
  id          String                   @id @default(uuid())
  paymentId   String
  raffleId    String
  creatorId   String
  buyerId     String
  type        FinancialTransactionType
  amountCents Int
  description String?
  createdAt   DateTime                 @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  raffle  Raffle  @relation(fields: [raffleId], references: [id])
  creator User    @relation("CreatorTransactions", fields: [creatorId], references: [id])
  buyer   User    @relation("BuyerTransactions", fields: [buyerId], references: [id])

  @@index([paymentId])
  @@index([raffleId])
  @@index([creatorId])
  @@index([buyerId])
  @@index([type])
  @@index([createdAt])
}

model PaymentAuditLog {
  id        String   @id @default(uuid())
  paymentId String
  action    String
  before    Json?
  after     Json?
  metadata  Json?
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([action])
  @@index([createdAt])
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  userId      String
  amountCents Int
  pixKey      String
  status      WithdrawalStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user     User  @relation("UserWithdrawals", fields: [userId], references: [id])
  reviewer User? @relation("WithdrawalReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PlatformFee {
  id          String   @id @default(uuid())
  key         String   @unique 
  description String
  basisPoints Int      
  isActive    Boolean  @default(true)
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedByUser User @relation(fields: [updatedBy], references: [id])

  @@index([isActive])
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   
  targetType String   
  targetId   String
  before     Json?    
  after      Json?    
  metadata   Json?    
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model Draw {
  id             String     @id @default(uuid())
  raffleId       String     @unique
  method         DrawMethod
  winnerTicketId String
  loteriaExtract String?
  executedAt     DateTime

  raffle       Raffle @relation(fields: [raffleId], references: [id])
  winnerTicket Ticket @relation(fields: [winnerTicketId], references: [id])
}

